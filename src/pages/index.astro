---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import PracticeAreas from '../components/PracticeAreas.astro';
import TeamSection from '../components/TeamSection.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations, url } from '../i18n/utils';

const t = useTranslations('tr');

// Fetch top 3 latest Turkish articles
const allPosts = await getCollection('blog', ({ data }) => data.lang === 'tr');
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout title="Ana Sayfa" description="NS Hukuk Danışmanlık - Av. Samet Ümit & Av. Öykü Naz Karaman tarafından kurulan, evrensel hukuk ilkelerine bağlı, stratejik ve güvenilir hukuki danışmanlık.">
  
  <!-- Hero Section -->
  <Hero />

  <!-- Practice Areas Section -->
  <PracticeAreas />

  <!-- Team Section -->
  <TeamSection />

  <!-- Recent Articles Section -->
  <section class="py-24 bg-cream-100 dark:bg-navy-900 transition-colors border-t border-navy-900/5 dark:border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16">
      
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div class="space-y-4">
          <span class="text-xs font-bold uppercase tracking-[0.2em] text-gold-600 dark:text-gold-400">
            {t('blog.title')}
          </span>
          <h2 class="text-3xl sm:text-5xl font-serif font-bold text-navy-900 dark:text-cream-100 tracking-tight">
            Güncel Hukuki Yayınlar
          </h2>
        </div>
        <a
          href={url('/makaleler')}
          class="inline-flex items-center gap-2 px-6 py-3 rounded text-xs font-bold uppercase tracking-widest bg-navy-900 text-cream-100 dark:bg-gold-500 dark:text-navy-950 hover:bg-gold-600 dark:hover:bg-gold-400 transition-all shadow-md hover:shadow-lg self-start md:self-auto"
        >
          <span>{t('blog.btn.all')}</span>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {latestPosts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>

    </div>
  </section>

  <!-- CTA Banner Section -->
  <section class="py-20 bg-gradient-to-r from-navy-950 via-navy-900 to-navy-950 text-white relative overflow-hidden border-t border-gold-500/20">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-gold-500/10 via-transparent to-transparent"></div>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-8 relative z-10">
      <h2 class="text-3xl sm:text-5xl font-serif font-bold tracking-tight">
        Hukuki Danışmanlık ve Çözüm Ortaklığı İçin <span class="text-gradient-gold">Yanınızdayız</span>
      </h2>
      <p class="text-sm sm:text-base text-cream-200 font-light max-w-2xl mx-auto leading-relaxed">
        Karmaşık hukuki süreçlerinizde doğru adımları atmak ve önleyici hukuk danışmanlığı hizmetlerimizden faydalanmak için bizimle iletişime geçin.
      </p>
      <div class="pt-4">
        <a
          href={url('/iletisim')}
          class="inline-block px-10 py-5 rounded text-xs font-bold uppercase tracking-[0.25em] bg-gold-500 text-navy-950 hover:bg-gold-400 transition-all shadow-2xl hover:shadow-gold-500/20 transform hover:-translate-y-0.5"
        >
          {t('hero.btn.contact')}
        </a>
      </div>
    </div>
  </section>

</Layout>
