---
import Layout from '../../../layouts/Layout.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('en');
const allPosts = await getCollection('blog', ({ data }) => data.lang === 'en');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Articles & Insights" description="Legal publications, regulatory reviews, and commentary authored by the attorneys at NS Law & Consultancy.">
  
  <!-- Page Header -->
  <section class="py-24 bg-navy-950 text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-gold-500/10 via-transparent to-transparent"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-6 relative z-10 animate-fade-in">
      <span class="text-xs font-bold uppercase tracking-[0.25em] text-gold-400">Knowledge & Regulation</span>
      <h1 class="text-4xl sm:text-6xl font-serif font-bold tracking-tight">
        Legal <span class="text-gradient-gold">Articles</span>
      </h1>
      <div class="w-20 h-0.5 bg-gold-500 mx-auto"></div>
      <p class="text-base sm:text-lg text-cream-200 font-light leading-relaxed">
        Expert analysis on corporate law, cross-border contracts, data protection, and landmark judicial decisions.
      </p>
    </div>
  </section>

  <!-- Articles Grid -->
  <section class="py-24 bg-cream-100 dark:bg-navy-900 transition-colors min-h-[60vh]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      {sortedPosts.length === 0 ? (
        <div class="text-center py-16 text-navy-600 dark:text-cream-400">
          No articles published yet. Stay tuned for our latest legal insights.
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {sortedPosts.map((post) => (
            <BlogCard post={post} />
          ))}
        </div>
      )}

    </div>
  </section>

</Layout>
