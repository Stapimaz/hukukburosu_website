---
import Layout from '../../../layouts/Layout.astro';
import { url } from '../../../i18n/utils';

export function getStaticPaths() {
  return [
    {
      params: { slug: 'samet' },
      props: {
        name: 'Atty. Samet Ümit',
        role: 'Founding Partner',
        image: url('/images/samet.png'),
        bar: 'Ankara Bar Association',
        email: 'samet@nshukuk.com',
        phone: '+90 544 646 73 49',
        languages: 'Turkish, English',
        practices: [
          'Company Incorporation & Corporate Structuring',
          'Mergers & Acquisitions (M&A)',
          'High-Value Commercial Contracts & Negotiation',
          'Corporate Risk Analysis & Debt Recovery',
          'Labor and Social Security Law',
          'Enforcement and Bankruptcy Law',
          'Commercial & Administrative Law',
          'Mediation & Dispute Resolution',
        ],
        education: [
          'Çankaya University Faculty of Law (Honors - Full Scholarship - 3 Years)',
          'Anadolu University Department of International Relations',
        ],
        bio: [
          'Graduating from Çankaya University Faculty of Law with full scholarship and honors in just 3 years, Atty. Samet Ümit reinforced his interdisciplinary vision with a degree in International Relations from Anadolu University.',
          'Throughout his career, he has provided comprehensive corporate counseling to nationwide companies in construction, manufacturing, and commerce, with a particular focus on building inspection firms. He possesses deep expertise in company formation, legal infrastructure of M&A processes, high-value commercial contract drafting, and corporate risk analysis.',
          'In addition to his extensive field and consultancy practice, he meticulously manages corporate debt recovery and complex dispute resolution in Labor and Social Security Law, Enforcement and Bankruptcy Law, Commercial Law, and Administrative Law.',
          'Having completed mediation training, Atty. Samet Ümit is fluent in English; alongside his legal work, he is keenly interested in legal tech, global economic trends, and management strategies. As a founder of NS Law & Consultancy, he continues to deliver high-capacity legal support at global standards to corporate and individual clients.',
        ],
      },
    },
    {
      params: { slug: 'oyku' },
      props: {
        name: 'Atty. Öykü Naz Karaman',
        role: 'Founding Partner',
        image: url('/images/oyku.png'),
        bar: 'Ankara Bar Association',
        email: 'oyku@nshukuk.com',
        phone: '+90 544 646 73 49',
        languages: 'Turkish, English',
        practices: [
          'Cross-Border Disputes & Litigation',
          'Market Integration for Foreign Enterprises',
          'Company Incorporation & Corporate Structuring',
          'Trademark Registration & IP Law',
          'Labor Law & Corporate Counseling',
          'Enforcement, Bankruptcy & Criminal Law',
          'Family and Inheritance Law',
        ],
        education: [
          'Bilkent University Faculty of Law (LL.B.)',
          'Tilburg University (LL.M. in European Law and Global Risk)',
        ],
        bio: [
          'Graduating successfully from Bilkent University Faculty of Law, Atty. Öykü Naz Karaman deepened her international legal vision through her LL.M. studies in European Law and Global Risk at Tilburg University.',
          'In her professional practice, she focuses particularly on cross-border disputes, playing an active role in market integration, company incorporation, corporate structuring, and trademark registration for foreign-invested enterprises in Turkey.',
          'Alongside providing corporate consultancy to domestic and international corporations, she specializes in Labor Law, Enforcement and Bankruptcy Law, Criminal Law, Family and Inheritance Law, and Intellectual Property Law, delivering dynamic and solution-oriented litigation services.',
          'Fluent in English, Atty. Öykü Naz Karaman participates in theater productions with the Ankara Bar Association Acting Workshop and enjoys international travel to explore new cultures. As a founder of NS Law & Consultancy, she continues to provide legal support at global standards to domestic and foreign clients.',
        ],
      },
    },
  ];
}

const { name, role, image, bar, email, phone, languages, practices, education, bio } = Astro.props;
---

<Layout title={`${name} - Biography`} description={`${name} biography and legal practice areas.`}>
  <div class="py-24 bg-cream-100 dark:bg-navy-900 transition-colors min-h-[80vh]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Back Link -->
      <a href={url('/en/about')} class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-gold-600 dark:text-gold-400 hover:text-navy-900 dark:hover:text-white transition-colors mb-12">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        <span>Back to Our Team</span>
      </a>

      <div class="bg-glass-card rounded-2xl overflow-hidden border border-navy-900/10 dark:border-white/10 shadow-xl grid grid-cols-1 lg:grid-cols-12 gap-0">
        
        <!-- Left Sidebar / Photo & Info -->
        <div class="lg:col-span-5 bg-navy-950 text-white p-8 sm:p-12 flex flex-col justify-between space-y-8 relative overflow-hidden">
          <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-gold-500/10 via-transparent to-transparent pointer-events-none"></div>
          
          <div class="space-y-6 relative z-10">
            <div class="rounded-xl overflow-hidden shadow-2xl aspect-[4/5] bg-navy-900 border border-gold-500/20">
              <img src={image} alt={name} class="w-full h-full object-cover object-top" />
            </div>
            
            <div class="space-y-2">
              <span class="text-xs uppercase tracking-[0.2em] text-gold-400 font-semibold">{role}</span>
              <h1 class="text-3xl sm:text-4xl font-serif font-bold tracking-tight">{name}</h1>
            </div>
          </div>

          <div class="space-y-4 pt-6 border-t border-white/10 text-xs text-cream-300 relative z-10">
            <div class="flex items-center gap-3">
              <span class="text-gold-400 font-semibold w-24 uppercase tracking-wider">Bar Admission:</span>
              <span>{bar}</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-gold-400 font-semibold w-24 uppercase tracking-wider">Languages:</span>
              <span>{languages}</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-gold-400 font-semibold w-24 uppercase tracking-wider">Phone:</span>
              <a href={`tel:${phone.replace(/\s+/g, '')}`} class="hover:text-gold-400 transition-colors">{phone}</a>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-gold-400 font-semibold w-24 uppercase tracking-wider">Email:</span>
              <a href={`mailto:${email}`} class="hover:text-gold-400 transition-colors">{email}</a>
            </div>
          </div>
        </div>

        <!-- Right Content / Biography & Details -->
        <div class="lg:col-span-7 p-8 sm:p-12 lg:p-16 space-y-12 bg-white/60 dark:bg-navy-900/60">
          
          <!-- Bio Section -->
          <div class="space-y-4">
            <h2 class="text-2xl font-serif font-bold text-navy-900 dark:text-cream-100 border-b border-gold-500/30 pb-2 inline-block">
              Biography
            </h2>
            <div class="space-y-4 text-sm sm:text-base text-navy-700 dark:text-cream-300/90 leading-relaxed font-light">
              {bio.map((paragraph: string) => (
                <p>{paragraph}</p>
              ))}
            </div>
          </div>

          <!-- Practice Areas -->
          <div class="space-y-4">
            <h2 class="text-2xl font-serif font-bold text-navy-900 dark:text-cream-100 border-b border-gold-500/30 pb-2 inline-block">
              Practice Areas
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {practices.map((item: string) => (
                <div class="flex items-center gap-2.5 p-3 rounded bg-navy-900/5 dark:bg-white/5 border border-navy-900/5 dark:border-white/5 text-xs font-medium text-navy-800 dark:text-cream-200">
                  <span class="w-1.5 h-1.5 rounded-full bg-gold-500"></span>
                  <span>{item}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Education -->
          <div class="space-y-4">
            <h2 class="text-2xl font-serif font-bold text-navy-900 dark:text-cream-100 border-b border-gold-500/30 pb-2 inline-block">
              Education
            </h2>
            <ul class="space-y-2 text-xs sm:text-sm text-navy-700 dark:text-cream-300/80">
              {education.map((edu: string) => (
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-gold-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  <span>{edu}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Direct CTA -->
          <div class="pt-6 border-t border-navy-900/10 dark:border-white/10">
            <a
              href={url('/en/contact')}
              class="inline-block px-8 py-4 rounded text-xs font-bold uppercase tracking-[0.2em] bg-navy-900 text-cream-100 dark:bg-gold-500 dark:text-navy-950 hover:bg-gold-600 dark:hover:bg-gold-400 transition-all shadow-lg"
            >
              Request Consultation
            </a>
          </div>

        </div>

      </div>

    </div>
  </div>
</Layout>
