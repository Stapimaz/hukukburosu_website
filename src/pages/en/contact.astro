---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('en');
---

<Layout title="Contact & Consultation" description="Get in touch with NS Law & Consultancy. Office address, phone, email, and online inquiry form.">
  
  <!-- Page Header -->
  <section class="py-24 bg-navy-950 text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-gold-500/10 via-transparent to-transparent"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-6 relative z-10 animate-fade-in">
      <span class="text-xs font-bold uppercase tracking-[0.25em] text-gold-400">Consultation & Inquiry</span>
      <h1 class="text-4xl sm:text-6xl font-serif font-bold tracking-tight">
        Contact <span class="text-gradient-gold">Us</span>
      </h1>
      <div class="w-20 h-0.5 bg-gold-500 mx-auto"></div>
      <p class="text-base sm:text-lg text-cream-200 font-light leading-relaxed">
        Reach out directly to our office for legal advice, dispute resolution, and corporate advisory requests.
      </p>
    </div>
  </section>

  <!-- Main Contact Section -->
  <section class="py-24 bg-cream-100 dark:bg-navy-900 transition-colors min-h-[70vh]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        
        <!-- Left Column: Contact Info Cards -->
        <div class="lg:col-span-5 space-y-8">
          
          <div class="space-y-4">
            <h2 class="text-2xl sm:text-3xl font-serif font-bold text-navy-900 dark:text-cream-100">
              Our Office Information
            </h2>
            <p class="text-xs sm:text-sm text-navy-700 dark:text-cream-300/80 leading-relaxed font-light">
              You can visit our office during working hours for appointment requests or contact us via phone or email for cross-border inquiries.
            </p>
          </div>

          <div class="space-y-6">
            <!-- Address Box -->
            <div class="bg-glass-card p-6 rounded-xl border border-navy-900/5 dark:border-white/5 flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg bg-navy-900 text-gold-400 flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              </div>
              <div class="space-y-1">
                <span class="text-[11px] font-bold uppercase tracking-widest text-gold-600 dark:text-gold-400">{t('contact.address.label')}</span>
                <p class="text-sm font-medium text-navy-900 dark:text-cream-100 leading-relaxed">
                  {t('contact.address.val')}
                </p>
              </div>
            </div>

            <!-- Phone Box -->
            <div class="bg-glass-card p-6 rounded-xl border border-navy-900/5 dark:border-white/5 flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg bg-navy-900 text-gold-400 flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              </div>
              <div class="space-y-1">
                <span class="text-[11px] font-bold uppercase tracking-widest text-gold-600 dark:text-gold-400">{t('contact.phone.label')}</span>
                <p class="text-sm font-medium text-navy-900 dark:text-cream-100">
                  <a href="tel:+902125550123" class="hover:text-gold-600 dark:hover:text-gold-400 transition-colors">{t('contact.phone.val')}</a>
                </p>
              </div>
            </div>

            <!-- Email Box -->
            <div class="bg-glass-card p-6 rounded-xl border border-navy-900/5 dark:border-white/5 flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg bg-navy-900 text-gold-400 flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <div class="space-y-1">
                <span class="text-[11px] font-bold uppercase tracking-widest text-gold-600 dark:text-gold-400">{t('contact.email.label')}</span>
                <p class="text-sm font-medium text-navy-900 dark:text-cream-100">
                  <a href="mailto:info@nshukuk.com" class="hover:text-gold-600 dark:hover:text-gold-400 transition-colors">{t('contact.email.val')}</a>
                </p>
              </div>
            </div>

            <!-- Working Hours Box -->
            <div class="bg-glass-card p-6 rounded-xl border border-navy-900/5 dark:border-white/5 flex items-start gap-4">
              <div class="w-12 h-12 rounded-lg bg-navy-900 text-gold-400 flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
              <div class="space-y-1">
                <span class="text-[11px] font-bold uppercase tracking-widest text-gold-600 dark:text-gold-400">{t('contact.hours.label')}</span>
                <p class="text-sm font-medium text-navy-900 dark:text-cream-100">
                  {t('contact.hours.val')}
                </p>
              </div>
            </div>
          </div>

        </div>

        <!-- Right Column: Google Forms Embed Area -->
        <div class="lg:col-span-7 bg-white/70 dark:bg-navy-950/70 p-8 sm:p-12 rounded-2xl border border-navy-900/10 dark:border-white/10 shadow-xl space-y-6">
          
          <div class="space-y-2 border-b border-navy-900/10 dark:border-white/10 pb-6">
            <h3 class="text-2xl font-serif font-bold text-navy-900 dark:text-cream-100">
              {t('contact.form.title')}
            </h3>
            <p class="text-xs sm:text-sm text-navy-700 dark:text-cream-300/80 leading-relaxed font-light">
              {t('contact.form.desc')}
            </p>
          </div>

          <!-- GOOGLE FORMS IFRAME CONTAINER -->
          <div class="w-full min-h-[600px] rounded-xl overflow-hidden bg-cream-50 dark:bg-navy-900 border border-navy-900/10 dark:border-white/10 relative flex flex-col items-center justify-center p-4">
            
            <!-- Dummy / Sample Form Placeholder (Replace src with your Google Form embed URL) -->
            <iframe
              src="https://docs.google.com/forms/d/e/1FAIpQLSeempty_placeholder_url/viewform?embedded=true"
              width="100%"
              height="650"
              frameborder="0"
              marginheight="0"
              marginwidth="0"
              class="w-full h-[650px] rounded-lg border-0 bg-transparent"
              title="NS Law Contact Form"
            >
              Loading…
            </iframe>

            <!-- Fallback explanation box -->
            <div class="absolute inset-x-8 inset-y-16 bg-white/95 dark:bg-navy-900/95 backdrop-blur-md p-8 rounded-xl border border-gold-500/40 flex flex-col items-center justify-center text-center space-y-4 pointer-events-none">
              <div class="w-12 h-12 rounded-full bg-gold-500/20 text-gold-600 dark:text-gold-400 flex items-center justify-center">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
              <h4 class="font-serif font-bold text-lg text-navy-900 dark:text-cream-100">Google Form Container Ready</h4>
              <p class="text-xs text-navy-700 dark:text-cream-300/80 max-w-md">
                Paste your Google Form embed link into the <code>iframe src=""</code> attribute inside <code>src/pages/en/contact.astro</code> to display your interactive form here.
              </p>
            </div>

          </div>

        </div>

      </div>

    </div>
  </section>

</Layout>
