---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const practices = [
  {
    icon: 'briefcase',
    title: lang === 'tr' ? 'Ticaret ve Şirketler Hukuku' : 'Commercial & Corporate Law',
    desc: lang === 'tr' 
      ? 'Şirket kuruluşları, birleşme & devralmalar (M&A), genel kurul işlemleri ve kurumsal yönetişim süreçlerinde uçtan uca hukuki danışmanlık.'
      : 'Comprehensive legal counsel on company formation, M&A transactions, general assemblies, and corporate governance.',
  },
  {
    icon: 'document',
    title: lang === 'tr' ? 'Sözleşmeler Hukuku' : 'Contract Law & Negotiations',
    desc: lang === 'tr'
      ? 'Ticari sözleşmelerin düzenlenmesi, uluslararası dağıtım, bayilik, lisans ve ortaklık sözleşmelerinin müzakeresi ve risk analizi.'
      : 'Drafting and negotiation of commercial agreements, distribution, licensing, and cross-border partnership contracts with risk mitigation.',
  },
  {
    icon: 'shield',
    title: lang === 'tr' ? 'KVKK ve Veri Güvenliği' : 'Data Protection & Privacy (KVKK)',
    desc: lang === 'tr'
      ? '6698 sayılı KVKK ve GDPR uyum projeleri, VERBİS süreçleri, veri envanteri hazırlığı ve Kurul denetimlerine karşı hukuki koruma.'
      : 'End-to-end compliance projects for Turkish Data Protection Law (KVKK) and GDPR, VERBİS registration, and data security audits.',
  },
  {
    icon: 'home',
    title: lang === 'tr' ? 'Gayrimenkul ve İnşaat Hukuku' : 'Real Estate & Construction',
    desc: lang === 'tr'
      ? 'Kat karşılığı inşaat sözleşmeleri, tapu iptal ve tescil davaları, kiralama süreçleri ve gayrimenkul yatırımları hukuki danışmanlığı.'
      : 'Legal support for construction contracts, title deed disputes, leasing transactions, and real estate investment projects.',
  },
  {
    icon: 'lightbulb',
    title: lang === 'tr' ? 'Fikri Mülkiyet Hukuku' : 'Intellectual Property',
    desc: lang === 'tr'
      ? 'Marka, patent, telif hakları ile ticari sırların korunması, haksız rekabet davaları ve TÜRKPATENT nezdindeki resmi işlemler.'
      : 'Protection of trademarks, patents, copyrights, trade secrets, unfair competition litigation, and TÜRKPATENT representation.',
  },
  {
    icon: 'scale',
    title: lang === 'tr' ? 'Uyuşmazlık Çözümü & Tahkim' : 'Dispute Resolution & Arbitration',
    desc: lang === 'tr'
      ? 'Ticari ve medeni uyuşmazlıklarda mahkemeler ve uluslararası tahkim kurumları nezdinde etkin, stratejik dava ve süreç takibi.'
      : 'Strategic representation and advocacy in commercial disputes before state courts and international arbitration tribunals.',
  },
];
---

<section id={lang === 'tr' ? 'uzmanliklar' : 'practice'} class="py-24 bg-cream-100 dark:bg-navy-900 transition-colors">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto space-y-4">
      <span class="text-xs font-bold uppercase tracking-[0.2em] text-gold-600 dark:text-gold-400">
        {lang === 'tr' ? 'Çalışma Alanlarımız' : 'What We Do'}
      </span>
      <h2 class="text-3xl sm:text-5xl font-serif font-bold text-navy-900 dark:text-cream-100 tracking-tight">
        {t('practice.title')}
      </h2>
      <div class="w-20 h-0.5 bg-gold-500 mx-auto"></div>
      <p class="text-sm sm:text-base text-navy-700 dark:text-cream-300 leading-relaxed font-light">
        {t('practice.subtitle')}
      </p>
    </div>

    <!-- Practice Areas Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {practices.map((item) => (
        <div class="bg-glass-card p-8 rounded-lg space-y-5 border border-navy-900/5 dark:border-white/5 hover:border-gold-500/50 group transition-all duration-300 relative overflow-hidden">
          
          <!-- Top Accent Line -->
          <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-gold-500 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          
          <!-- Icon Box -->
          <div class="w-12 h-12 rounded bg-navy-900 dark:bg-gold-500/10 text-gold-400 dark:text-gold-400 flex items-center justify-center group-hover:scale-110 transition-transform">
            {item.icon === 'briefcase' && (
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            )}
            {item.icon === 'document' && (
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            )}
            {item.icon === 'shield' && (
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            )}
            {item.icon === 'home' && (
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
            )}
            {item.icon === 'lightbulb' && (
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path></svg>
            )}
            {item.icon === 'scale' && (
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path></svg>
            )}
          </div>

          <!-- Title & Description -->
          <h3 class="text-xl font-serif font-bold text-navy-900 dark:text-cream-100 group-hover:text-gold-600 dark:group-hover:text-gold-400 transition-colors">
            {item.title}
          </h3>
          <p class="text-xs sm:text-sm text-navy-700 dark:text-cream-300/80 leading-relaxed font-light">
            {item.desc}
          </p>

        </div>
      ))}
    </div>

  </div>
</section>
