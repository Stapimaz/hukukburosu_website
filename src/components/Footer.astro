---
import { getLangFromUrl, useTranslations, url } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();
---

<footer class="bg-navy-950 text-cream-200 pt-16 pb-10 border-t border-gold-500/20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 pb-12 border-b border-white/10">
      <!-- Col 1: Brand & About -->
      <div class="space-y-4">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-sm bg-gold-500/20 border border-gold-500 flex items-center justify-center">
            <span class="font-serif font-bold text-lg text-gradient-gold">NS</span>
          </div>
          <span class="font-serif font-bold tracking-wider text-white text-lg">
            NS HUKUK DANIŞMANLIK
          </span>
        </div>
        <p class="text-xs text-cream-300/80 leading-relaxed">
          {t('footer.desc')}
        </p>
        <div class="pt-2 flex items-center gap-4 text-gold-400">
          <span class="text-xs tracking-widest uppercase font-semibold">{lang === 'tr' ? 'Çankaya / Ankara' : 'Cankaya / Ankara'}</span>
        </div>
      </div>

      <!-- Col 2: Quick Links -->
      <div>
        <h4 class="font-serif font-semibold text-white text-base tracking-wide mb-4 pb-2 border-b border-gold-500/30 inline-block">
          {lang === 'tr' ? 'Hızlı Bağlantılar' : 'Quick Links'}
        </h4>
        <ul class="space-y-2 text-xs">
          <li>
            <a href={url(lang === 'tr' ? '/' : '/en/')} class="hover:text-gold-400 transition-colors">
              {t('nav.home')}
            </a>
          </li>
          <li>
            <a href={url(lang === 'tr' ? '/hakkimizda' : '/en/about')} class="hover:text-gold-400 transition-colors">
              {t('nav.about')}
            </a>
          </li>
          <li>
            <a href={url(lang === 'tr' ? '/#uzmanliklar' : '/en/#practice')} class="hover:text-gold-400 transition-colors">
              {t('nav.practice')}
            </a>
          </li>
          <li>
            <a href={url(lang === 'tr' ? '/makaleler' : '/en/articles')} class="hover:text-gold-400 transition-colors">
              {t('nav.blog')}
            </a>
          </li>
          <li>
            <a href={url(lang === 'tr' ? '/iletisim' : '/en/contact')} class="hover:text-gold-400 transition-colors">
              {t('nav.contact')}
            </a>
          </li>
        </ul>
      </div>

      <!-- Col 3: Practice Areas -->
      <div>
        <h4 class="font-serif font-semibold text-white text-base tracking-wide mb-4 pb-2 border-b border-gold-500/30 inline-block">
          {t('practice.title')}
        </h4>
        <ul class="space-y-2 text-xs text-cream-300/80">
          <li>{lang === 'tr' ? 'Ticaret ve Şirketler Hukuku' : 'Commercial & Corporate Law'}</li>
          <li>{lang === 'tr' ? 'Sözleşmeler Hukuku & Müzakere' : 'Contract Law & Negotiation'}</li>
          <li>{lang === 'tr' ? 'KVKK ve Veri Güvenliği Uyumu' : 'Data Protection & Privacy (KVKK)'}</li>
          <li>{lang === 'tr' ? 'Gayrimenkul ve İnşaat Hukuku' : 'Real Estate & Construction Law'}</li>
          <li>{lang === 'tr' ? 'Fikri Mülkiyet ve Marka Hukuku' : 'Intellectual Property Law'}</li>
          <li>{lang === 'tr' ? 'Uyuşmazlık Çözümü & Dava Takibi' : 'Dispute Resolution & Litigation'}</li>
        </ul>
      </div>

      <!-- Col 4: Contact Summary -->
      <div>
        <h4 class="font-serif font-semibold text-white text-base tracking-wide mb-4 pb-2 border-b border-gold-500/30 inline-block">
          {t('contact.title')}
        </h4>
        <ul class="space-y-3 text-xs text-cream-300/80">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-gold-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span>{t('contact.address.val')}</span>
          </li>
          <li class="flex items-center gap-2.5">
            <svg class="w-4 h-4 text-gold-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            <span>{t('contact.phone.val')}</span>
          </li>
          <li class="flex items-center gap-2.5">
            <svg class="w-4 h-4 text-gold-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <span>{t('contact.email.val')}</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Legal & Copyright -->
    <div class="pt-8 flex flex-col md:flex-row items-center justify-between text-[11px] text-cream-300/60 gap-4">
      <p>
        &copy; {currentYear} NS Hukuk Danışmanlık. {t('footer.rights')}
      </p>
      <p class="max-w-md text-center md:text-right italic">
        {t('footer.disclaimer')}
      </p>
    </div>
  </div>
</footer>
