---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative py-20 sm:py-28 lg:py-32 flex items-center justify-center overflow-hidden bg-cream-100 transition-colors">
  <!-- Architectural Grid Lines & Subtle Warm Glow (No Badges, No Boxes, No Murky Photos!) -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <!-- Faint Vertical Architectural Columns -->
    <div class="max-w-7xl mx-auto h-full border-x border-navy-900/[0.04] flex justify-between">
      <div class="w-px h-full bg-navy-900/[0.04] hidden sm:block"></div>
      <div class="w-px h-full bg-navy-900/[0.04] hidden md:block"></div>
      <div class="w-px h-full bg-navy-900/[0.04] hidden lg:block"></div>
    </div>
    <!-- Soft Luminous Gold Glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[400px] bg-gold-500/10 rounded-full blur-[140px]"></div>
  </div>

  <!-- Main Content Container -->
  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-12 animate-fade-in">
    
    <!-- Top Editorial Tag (NO BADGE / NO PILL / NO BOX) -->
    <div class="flex items-center justify-center gap-4">
      <span class="w-8 sm:w-12 h-px bg-gold-500/60"></span>
      <span class="text-xs sm:text-sm tracking-[0.25em] uppercase font-semibold text-gold-700">
        {lang === 'tr' ? 'Ulusal ve Uluslararası Hukuk Danışmanlığı' : 'National & International Legal Consultancy'}
      </span>
      <span class="w-8 sm:w-12 h-px bg-gold-500/60"></span>
    </div>

    <!-- Monumental High-Contrast Title (Deep Navy #060a18 & Gold) -->
    <div class="space-y-4">
      <h1 class="text-5xl sm:text-7xl md:text-8xl font-serif font-bold text-navy-950 tracking-tight leading-none">
        NS HUKUK <span class="italic font-normal text-gradient-gold">DANIŞMANLIK</span>
      </h1>
    </div>

    <!-- Visionary Single-Line Latin Quote (NO BOX / NO CORNER BRACKETS / NO BADGE) -->
    <div class="max-w-5xl mx-auto py-8 border-y border-navy-900/10 my-6 relative">
      <!-- Delicate Center Diamond Ornament on Border -->
      <span class="absolute -top-[3px] left-1/2 -translate-x-1/2 w-1.5 h-1.5 rotate-45 bg-gold-500"></span>
      <span class="absolute -bottom-[3px] left-1/2 -translate-x-1/2 w-1.5 h-1.5 rotate-45 bg-gold-500"></span>

      <p class="font-serif italic text-lg sm:text-2xl md:text-3xl lg:text-[32px] text-navy-900 font-normal tracking-wide sm:whitespace-nowrap text-center">
        "{t('hero.quote')}"
      </p>
    </div>

    <!-- Subtitle -->
    <p class="text-base sm:text-lg md:text-xl text-navy-700 font-light tracking-wide max-w-3xl mx-auto leading-relaxed text-center">
      {t('hero.subtitle')}
    </p>

  </div>

  <!-- Bottom Transition Divider -->
  <div class="absolute bottom-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-gold-500/30 to-transparent"></div>
</section>
