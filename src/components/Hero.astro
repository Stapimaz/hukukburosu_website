---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative py-16 sm:py-20 lg:py-24 flex items-center justify-center overflow-hidden bg-gradient-to-b from-navy-950 via-navy-900 to-navy-950 border-b-2 border-gold-500/30 shadow-xl">
  <!-- Subtle Architectural & Decorative Background -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <!-- Sophisticated Architectural Line Pattern & Warm Glow (No Murky Photos!) -->
    <div class="absolute -top-32 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-gold-500/15 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 inset-x-0 h-1/2 bg-gradient-to-t from-navy-950/80 to-transparent"></div>
    <div class="absolute inset-0 bg-[radial-gradient(#C5A880_1px,transparent_1px)] [background-size:32px_32px] opacity-10"></div>
  </div>

  <!-- Content Container -->
  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-8 animate-fade-in">
    
    <!-- Top Accent Tag (Clean, High Contrast, Static Gold Diamonds) -->
    <div class="inline-flex items-center gap-2.5 px-5 py-2 rounded-full bg-navy-800/90 border border-gold-500/40 shadow-lg backdrop-blur-md text-gold-300 text-xs tracking-[0.25em] uppercase font-semibold">
      <span class="w-1.5 h-1.5 rotate-45 bg-gold-400 flex-shrink-0"></span>
      <span>{lang === 'tr' ? 'Ulusal ve Uluslararası Hukuk Danışmanlığı' : 'National & International Legal Consultancy'}</span>
      <span class="w-1.5 h-1.5 rotate-45 bg-gold-400 flex-shrink-0"></span>
    </div>

    <!-- Main Title (Pristine White & Gold with Razor-Sharp Contrast) -->
    <div class="space-y-3">
      <h1 class="text-4xl sm:text-6xl md:text-7xl font-serif font-bold text-white tracking-tight leading-tight drop-shadow-md">
        NS HUKUK <span class="text-gradient-gold">DANIŞMANLIK</span>
      </h1>
      <div class="w-28 h-0.5 bg-gradient-to-r from-transparent via-gold-500 to-transparent mx-auto"></div>
    </div>

    <!-- Visionary Latin Quote & Subtitle (Single Line! No CTA Buttons!) -->
    <div class="max-w-4xl mx-auto pt-2 space-y-6">
      
      <!-- Single Line Latin Quote Statement -->
      <div class="relative py-4 px-6 sm:px-10 rounded-xl bg-navy-950/70 border border-gold-500/35 shadow-2xl backdrop-blur-md">
        <!-- Delicate Gold Corner Ornaments -->
        <span class="absolute top-2 left-2 w-2.5 h-2.5 border-t border-l border-gold-400/70"></span>
        <span class="absolute top-2 right-2 w-2.5 h-2.5 border-t border-r border-gold-400/70"></span>
        <span class="absolute bottom-2 left-2 w-2.5 h-2.5 border-b border-l border-gold-400/70"></span>
        <span class="absolute bottom-2 right-2 w-2.5 h-2.5 border-b border-r border-gold-400/70"></span>

        <p class="font-serif italic text-base sm:text-xl md:text-2xl lg:text-[26px] text-gold-200 font-normal tracking-wide sm:whitespace-nowrap overflow-hidden text-ellipsis">
          "{t('hero.quote')}"
        </p>
      </div>

      <!-- Refined Subtitle -->
      <p class="text-sm sm:text-base md:text-lg text-cream-200 font-light tracking-wide max-w-2xl mx-auto leading-relaxed">
        {t('hero.subtitle')}
      </p>

    </div>

  </div>
</section>
