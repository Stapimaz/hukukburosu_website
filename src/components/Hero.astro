---
import { getLangFromUrl, useTranslations, url } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative py-20 lg:py-28 flex items-center justify-center overflow-hidden bg-gradient-to-b from-cream-100 via-cream-100 to-cream-200/70 border-b border-gold-500/20">
  <!-- Soft Background Glow & Decorative Elements -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <!-- Subtle Watermark Image -->
    <img
      src={url('/images/hero-bg.png')}
      alt="NS Hukuk Danışmanlık"
      class="w-full h-full object-cover object-center opacity-[0.06] grayscale mix-blend-multiply scale-105"
    />
    <!-- Warm Gold Glow at Top Center -->
    <div class="absolute -top-32 left-1/2 -translate-x-1/2 w-[700px] h-[350px] bg-gold-500/10 rounded-full blur-[100px]"></div>
    <!-- Elegant Geometric Line -->
    <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-gold-500/30 to-transparent"></div>
  </div>

  <!-- Content Container -->
  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-10 animate-fade-in">
    
    <!-- Top Accent Tag (Clean, Static, No Blinking Effect) -->
    <div class="inline-flex items-center gap-2.5 px-5 py-2 rounded-full bg-white/80 border border-gold-500/30 shadow-sm backdrop-blur-md text-gold-700 text-xs tracking-[0.25em] uppercase font-semibold">
      <span class="w-1.5 h-1.5 rotate-45 bg-gold-500 flex-shrink-0"></span>
      <span>{lang === 'tr' ? 'Ulusal ve Uluslararası Hukuk Danışmanlığı' : 'National & International Legal Consultancy'}</span>
      <span class="w-1.5 h-1.5 rotate-45 bg-gold-500 flex-shrink-0"></span>
    </div>

    <!-- Main Title -->
    <div class="space-y-4">
      <h1 class="text-4xl sm:text-6xl md:text-7xl font-serif font-bold text-navy-950 tracking-tight leading-tight">
        NS HUKUK <span class="text-gradient-gold">DANIŞMANLIK</span>
      </h1>
      <div class="w-24 h-0.5 bg-gradient-to-r from-transparent via-gold-500 to-transparent mx-auto"></div>
    </div>

    <!-- Latin Quote Card (Light, Refined & Elegant) -->
    <div class="max-w-3xl mx-auto py-8 px-6 sm:px-10 rounded-2xl bg-white/70 border border-gold-500/25 shadow-xl shadow-navy-950/[0.03] backdrop-blur-md relative space-y-5">
      <!-- Decorative Corner Accents -->
      <span class="absolute top-3 left-3 w-3 h-3 border-t border-l border-gold-500/40"></span>
      <span class="absolute top-3 right-3 w-3 h-3 border-t border-r border-gold-500/40"></span>
      <span class="absolute bottom-3 left-3 w-3 h-3 border-b border-l border-gold-500/40"></span>
      <span class="absolute bottom-3 right-3 w-3 h-3 border-b border-r border-gold-500/40"></span>

      <p class="font-serif italic text-xl sm:text-2xl md:text-3xl text-navy-900 font-normal leading-relaxed tracking-wide">
        "{t('hero.quote')}"
      </p>
      
      <div class="flex items-center justify-center gap-3">
        <div class="h-px w-8 bg-gold-500/40"></div>
        <span class="w-1.5 h-1.5 rounded-full bg-gold-500"></span>
        <div class="h-px w-8 bg-gold-500/40"></div>
      </div>

      <p class="text-sm sm:text-base text-navy-700 font-light tracking-wide max-w-2xl mx-auto leading-relaxed">
        {t('hero.subtitle')}
      </p>
    </div>

    <!-- Call to Action Buttons -->
    <div class="pt-2 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={url(lang === 'tr' ? '/iletisim' : '/en/contact')}
        class="w-full sm:w-auto px-8 py-4 rounded-lg text-xs font-bold uppercase tracking-[0.2em] bg-navy-950 text-white hover:bg-gold-500 hover:text-navy-950 transition-all shadow-lg shadow-navy-950/10 hover:shadow-gold-500/20 transform hover:-translate-y-0.5 duration-200"
      >
        {t('hero.btn.contact')}
      </a>
      <a
        href={url(lang === 'tr' ? '/#uzmanliklar' : '/en/#practice')}
        class="w-full sm:w-auto px-8 py-4 rounded-lg text-xs font-bold uppercase tracking-[0.2em] bg-white/90 border border-navy-950/15 text-navy-950 hover:border-gold-500 hover:text-gold-700 hover:bg-white transition-all shadow-sm transform hover:-translate-y-0.5 duration-200"
      >
        {t('hero.btn.practice')}
      </a>
    </div>

  </div>
</section>
