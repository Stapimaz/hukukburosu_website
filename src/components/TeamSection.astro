---
import { getLangFromUrl, useTranslations, url } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const team = [
  {
    slug: 'oyku',
    name: lang === 'tr' ? 'Av. Öykü Naz Karaman' : 'Atty. Öykü Naz Karaman',
    role: lang === 'tr' ? 'Kurucu Ortak' : 'Founding Partner',
    practice: lang === 'tr' ? 'Şirketler Hukuku, Sınır Ötesi Uyuşmazlıklar & Dava Takibi' : 'Corporate Law, Cross-Border Disputes & Litigation',
    image: url('/images/oyku.png'),
    bio: lang === 'tr'
      ? 'Bilkent Üniversitesi Hukuk Fakültesi mezunu olan Av. Öykü Naz Karaman, uluslararası hukuk vizyonunu Tilburg Üniversitesi European Law and Global Risk yüksek lisansı ile derinleştirmiştir. Sınır ötesi uyuşmazlıklar, yabancı şirketlerin Türkiye pazar entegrasyonu, İş, İcra-İflas ve Fikri Mülkiyet Hukuku alanlarında uzmanlaşmış olup, dinamik ve çözüm odaklı dava takibi ile kurumsal danışmanlık hizmeti sunmaktadır.'
      : 'A graduate of Bilkent University Faculty of Law with an LL.M. in European Law and Global Risk from Tilburg University, Atty. Öykü Naz Karaman focuses on cross-border disputes, market integration for foreign enterprises, and corporate compliance. She specializes in Labor Law, Enforcement & Bankruptcy, Criminal, and Intellectual Property Law, providing dynamic litigation and counseling at global standards.',
  },
  {
    slug: 'samet',
    name: lang === 'tr' ? 'Av. Samet Ümit' : 'Atty. Samet Ümit',
    role: lang === 'tr' ? 'Kurucu Ortak' : 'Founding Partner',
    practice: lang === 'tr' ? 'Kurumsal Danışmanlık, Ticari Sözleşmeler & M&A' : 'Corporate Counseling, Commercial Contracts & M&A',
    image: url('/images/samet.png'),
    bio: lang === 'tr'
      ? 'Çankaya Üniversitesi Hukuk Fakültesi’ni tam burslu ve şeref derecesiyle 3 yılda tamamlayan Av. Samet Ümit, vizyonunu Anadolu Üniversitesi Uluslararası İlişkiler diploması ile pekiştirmiştir. Yapı denetim, inşaat, üretim ve ticaret sektörlerindeki şirketlere tam kapsamlı danışmanlık sunmakta; M&A, yüksek bütçeli ticari sözleşmeler, kurumsal risk analizi ve alacak tahsili süreçlerini titizlikle yönetmektedir.'
      : 'Graduating from Çankaya University Faculty of Law with full scholarship and honors in just 3 years, Atty. Samet Ümit holds an additional degree in International Relations. He provides comprehensive legal counseling to corporations in construction, manufacturing, and trade; specializing in M&A transactions, high-value commercial contracts, risk analysis, and complex dispute resolution.',
  },
];
---

<section id="ekip" class="py-24 bg-cream-200 dark:bg-navy-950 transition-colors border-t border-navy-900/5 dark:border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16">
    
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto space-y-4">
      <span class="text-xs font-bold uppercase tracking-[0.2em] text-gold-600 dark:text-gold-400">
        {lang === 'tr' ? 'Liderlik & Vizyon' : 'Leadership & Vision'}
      </span>
      <h2 class="text-3xl sm:text-5xl font-serif font-bold text-navy-900 dark:text-cream-100 tracking-tight">
        {t('team.title')}
      </h2>
      <div class="w-20 h-0.5 bg-gold-500 mx-auto"></div>
      <p class="text-sm sm:text-base text-navy-700 dark:text-cream-300 leading-relaxed font-light">
        {t('team.subtitle')}
      </p>
    </div>

    <!-- Founder Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-5xl mx-auto">
      {team.map((member) => (
        <div class="bg-glass-card rounded-xl overflow-hidden border border-navy-900/10 dark:border-white/10 hover:border-gold-500 transition-all duration-500 group flex flex-col shadow-lg hover:shadow-2xl">
          
          <!-- Image Container -->
          <div class="relative h-96 sm:h-[420px] overflow-hidden bg-navy-900">
            <img
              src={member.image}
              alt={member.name}
              class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700 opacity-95"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-navy-950 via-transparent to-transparent opacity-80"></div>
            
            <!-- Bottom Floating Tag inside Image -->
            <div class="absolute bottom-4 left-6 right-6">
              <span class="text-[11px] uppercase tracking-widest text-gold-400 font-semibold block">
                {member.role}
              </span>
              <h3 class="text-2xl sm:text-3xl font-serif font-bold text-white tracking-wide">
                {member.name}
              </h3>
            </div>
          </div>

          <!-- Content Body -->
          <div class="p-8 space-y-6 flex-1 flex flex-col justify-between bg-white/40 dark:bg-navy-900/40">
            <div class="space-y-3">
              <div class="text-xs font-medium text-gold-600 dark:text-gold-400 flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-gold-500"></span>
                <span>{member.practice}</span>
              </div>
              <p class="text-xs sm:text-sm text-navy-700 dark:text-cream-300/80 leading-relaxed font-light">
                {member.bio}
              </p>
            </div>

            <div class="pt-4 border-t border-navy-900/10 dark:border-white/10 flex items-center justify-between">
              <a
                href={url(lang === 'tr' ? `/ekip/${member.slug}` : `/en/team/${member.slug}`)}
                class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-navy-900 dark:text-gold-400 group-hover:text-gold-600 dark:group-hover:text-gold-300 transition-colors"
              >
                <span>{t('team.btn.profile')}</span>
                <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </a>
              <div class="flex items-center gap-3 text-navy-700 dark:text-cream-400">
                <span class="w-8 h-8 rounded-full bg-navy-900/5 dark:bg-white/5 flex items-center justify-center hover:bg-gold-500 hover:text-navy-950 transition-colors">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                </span>
              </div>
            </div>

          </div>

        </div>
      ))}
    </div>

  </div>
</section>
